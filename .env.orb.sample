# AngelOne credentials
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_KEY=

# ORB strategy mode
ORB_PAPER_MODE=1
ORB_LIVE_MODE=0
ORB_POLL_SECONDS=3
ORB_CAPITAL_PER_TRADE=30000

# ORB timing
ORB_ORB_START=09:15
ORB_ORB_END=09:30
ORB_LAST_ENTRY=14:30
ORB_FORCE_EXIT=15:15

# Breakout and volume confirmation
ORB_REQUIRE_VOLUME_SPIKE=1
ORB_VOLUME_SPIKE_MULT=1.4
ORB_BREAKOUT_BUFFER=1.0

# Risk and exits
ORB_USE_OPPOSITE_ORB_SL=1
ORB_FIXED_SL_POINTS=18
ORB_RR_RATIO=1.5
ORB_TRAIL_MODE=orb_mid
ORB_MAX_TRADES_PER_DAY=2
ORB_MAX_REENTRY_PER_DIRECTION=1
ORB_REVENGE_COOLDOWN_MIN=15

# No-trade filters
ORB_SKIP_LOW_VOL_DAY=1
ORB_MIN_ORB_RANGE=22
ORB_GAP_FILTER=1
ORB_MAX_GAP_PCT=1.0
ORB_NEWS_EVENT_BLOCK=0

# Telegram alerts
ORB_TELEGRAM_ENABLED=0
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
